# CECI ML Pipeline Environment Configuration

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Pipeline Configuration
MIN_SESSIONS=1
GREEN_THRESHOLD=70.0
AMBER_THRESHOLD=40.0

# Monitoring
ENABLE_METRICS=true
METRICS_EXPORT_DIR=metrics

# Database (if needed in future)
# DATABASE_URL=postgresql://user:password@localhost:5432/ceci_db
