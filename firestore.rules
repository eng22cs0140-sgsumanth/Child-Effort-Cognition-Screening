rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Helper: is an approved doctor?
    function isApprovedDoctor(uid) {
      let doc = get(/databases/$(database)/documents/doctors/$(uid));
      return doc.exists && doc.data.status == 'approved';
    }

    // -----------------------------------------------------------------------
    // users collection — each user reads/writes their own document
    // -----------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // -----------------------------------------------------------------------
    // admin collection — only admin can read/write
    // -----------------------------------------------------------------------
    match /admin/{uid} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // -----------------------------------------------------------------------
    // parents collection — each parent owns their own document
    // -----------------------------------------------------------------------
    match /parents/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // -----------------------------------------------------------------------
    // children collection
    //   - Parent who owns the child can read and write
    //   - Assigned approved doctor can read only (not write)
    //   - Admin can do anything
    // -----------------------------------------------------------------------
    match /children/{childId} {
      allow read: if request.auth != null && (
        resource.data.parentUid == request.auth.uid
        || (isApprovedDoctor(request.auth.uid)
            && resource.data.assignedDoctorUid == request.auth.uid)
        || isAdmin()
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.parentUid == request.auth.uid || isAdmin()
      );

      // Sessions sub-collection — same parent/doctor/admin rules
      match /sessions/{sessionId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid
          || (isApprovedDoctor(request.auth.uid)
              && get(/databases/$(database)/documents/children/$(childId)).data.assignedDoctorUid == request.auth.uid)
          || isAdmin()
        );
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid
          || isAdmin()
        );
      }
    }

    // -----------------------------------------------------------------------
    // doctors collection
    //   - Doctor reads/writes their own document
    //   - Admin can read/write all
    // -----------------------------------------------------------------------
    match /doctors/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow delete: if request.auth != null && isAdmin();
    }

    // -----------------------------------------------------------------------
    // doctorOtps collection
    //   - Approved doctor can create/update their own OTPs
    //   - Any authenticated user can read (to verify OTP during linking)
    //   - Only the system (via a parent's auth) can mark as used
    // -----------------------------------------------------------------------
    match /doctorOtps/{otp} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isApprovedDoctor(request.auth.uid)
                    && request.resource.data.doctorUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }
  }
}
