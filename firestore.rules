rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return exists(/databases/$(database)/documents/admin/$(request.auth.uid));
    }

    // Helper: is an approved doctor?
    function isApprovedDoctor(uid) {
      let doc = get(/databases/$(database)/documents/doctors/$(uid));
      return doc.exists && doc.data.status == 'approved';
    }

    // -----------------------------------------------------------------------
    // users collection
    // -----------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // -----------------------------------------------------------------------
    // admin collection — only admins can read/write
    // (isAdmin() uses exists() which bypasses rules, so bootstrap is safe)
    // -----------------------------------------------------------------------
    match /admin/{uid} {
      allow read, write: if request.auth != null && isAdmin();
    }

    // -----------------------------------------------------------------------
    // parents collection
    // -----------------------------------------------------------------------
    match /parents/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // -----------------------------------------------------------------------
    // children collection
    //   - Parent who owns the child can read and write
    //   - Assigned approved doctor can read only
    //   - Admin can do anything
    // -----------------------------------------------------------------------
    match /children/{childId} {
      allow read: if request.auth != null && (
        resource.data.parentUid == request.auth.uid
        || (isApprovedDoctor(request.auth.uid)
            && resource.data.assignedDoctorUid == request.auth.uid)
        || isAdmin()
      );
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.parentUid == request.auth.uid || isAdmin()
      );

      // Sessions sub-collection
      match /sessions/{sessionId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid
          || (isApprovedDoctor(request.auth.uid)
              && get(/databases/$(database)/documents/children/$(childId)).data.assignedDoctorUid == request.auth.uid)
          || isAdmin()
        );
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/children/$(childId)).data.parentUid == request.auth.uid
          || isAdmin()
        );
      }
    }

    // -----------------------------------------------------------------------
    // doctors collection
    //   - Doctor reads/writes their own document
    //   - Admin can read/write all
    //   - Any authenticated user may add to assignedChildIds ONLY
    //     (this is triggered when a parent links a child via OTP)
    // -----------------------------------------------------------------------
    match /doctors/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && (
        request.auth.uid == uid
        || isAdmin()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedChildIds'])
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // -----------------------------------------------------------------------
    // doctorOtps collection
    //   - Any authenticated user can read (to verify OTP during linking)
    //   - Approved doctor can create their own OTP
    //   - Any authenticated user can mark as used (update)
    //   - Admin can delete
    // -----------------------------------------------------------------------
    match /doctorOtps/{otp} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.doctorUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && isAdmin();
    }
  }
}
