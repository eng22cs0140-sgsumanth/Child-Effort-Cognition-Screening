# CECI Assessment App - Environment Configuration

# ML Pipeline API URL
# Set this to the URL where your ML Pipeline is running
# Development: http://localhost:8000
# Production: https://your-api-domain.com
VITE_API_BASE_URL=http://localhost:8000

# Enable/Disable ML Pipeline Integration
# Set to 'true' to use Python ML Pipeline API
# Set to 'false' to use local TypeScript implementation only
VITE_USE_ML_PIPELINE=true

# API Timeout (milliseconds)
VITE_API_TIMEOUT=10000

# Fallback to local calculation if API fails
VITE_ENABLE_FALLBACK=true

# Debug mode
VITE_DEBUG=false
